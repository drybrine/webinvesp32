  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "check-env": "node scripts/check-env.js",
    "dev": "npm run check-env && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
