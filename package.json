    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint": "9.30.0",
    "eslint-config-next": "^16.2.6",
    "firebase-tools": "^15.21.0",
    "postcss": "^8.5.15",
    "sharp": "^0.35.3",
