{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    },
    "api/predict.py": {
      "runtime": "@vercel/python@4.3.1",
      "maxDuration": 30
    },
    "api/lookup.py": {
      "runtime": "@vercel/python@4.3.1",
      "maxDuration": 15
    }
  },
  "cleanUrls": true,
  "trailingSlash": false
}
