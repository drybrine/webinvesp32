# Firebase Configuration Template
# Copy file ini ke .env.local dan isi dengan nilai yang sebenarnya

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.region.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id
ALLOWED_ORIGINS=https://stokmanager.app,https://your-project.vercel.app

# Firebase Admin untuk Vercel Functions (server-only, JSON satu baris;
# private_key boleh menggunakan karakter escaped \\n). Jangan commit nilai asli.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your_project_id","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com"}

# One-time admin bootstrap (bisa memakai FIREBASE_SERVICE_ACCOUNT di atas
# atau Application Default Credentials saat dijalankan lokal)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace_with_at_least_12_characters
BOOTSTRAP_ADMIN_NAME=Administrator

# Development settings
NODE_ENV=development
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
